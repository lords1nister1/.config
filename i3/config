set $mod Mod4
font pango:monospace 10
floating_modifier $mod

bindsym $mod+Return exec kitty
bindsym $mod+q kill
bindsym $mod+d exec rofi -show drun
bindsym $mod+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"
bindsym $mod+b exec brave
bindsym $mod+Shift+b exec brave --incognito 
bindsym $mod+e exec dolphin
bindsym $mod+Left move left
bindsym $mod+Down move down
bindsym $mod+Up move up
bindsym $mod+Right move right
bindsym $mod+f fullscreen toggle
bindsym $mod+space floating toggle

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym XF86AudioRaiseVolume exec sh -c 'pamixer -i 5 && dunstify -t 200 "Volume" "$(pamixer --get-volume)%"'
bindsym XF86AudioLowerVolume exec sh -c 'pamixer -d 5 && dunstify -t 200 "Volume" "$(pamixer --get-volume)%"'
bindsym XF86AudioMute exec sh -c 'pamixer -t && notify-send "Volume" "Mute toggled"'

bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioStop exec playerctl stop

bindsym XF86MonBrightnessUp exec ~/.config/i3/scripts/brightness-notify +10%
bindsym XF86MonBrightnessDown exec ~/.config/i3/scripts/brightness-notify 10%-
bindsym XF86KbdBrightnessUp exec ~/.config/i3/scripts/kbd-brightness-notify +10%
bindsym XF86KbdBrightnessDown exec ~/.config/i3/scripts/kbd-brightness-notify 10%-

bindsym $mod+s exec --no-startup-id flameshot gui

exec_always --no-startup-id flameshot
exec_always --no-startup-id picom
exec_always --no-startup-id dunst
exec_always --no-startup-id nm-applet
exec_always --no-startup-id xfce4-power-manager
exec_always --no-startup-id xrandr --output eDP-1 --scale 1.1x1.1
exec_always --no-startup-id libinput-gestures
exec_always --no-startup-id xinput set-prop "bcm5974" "libinput Natural Scrolling Enabled" 1
# exec_always --no-startup-id exec_always --no-startup-id xrandr --output eDP-1 --mode "1680x1050_60.00"
exec_always --no-startup-id xrandr --output eDP-1 --mode 1680x1050
exec_always --no-startup-id xset s off
exec_always --no-startup-id xset -dpms
exec_always --no-startup-id xset s noblank
exec --no-startup-id kitty

bar {
    status_command i3status
    position top
    mode dock
    workspace_buttons yes
}
